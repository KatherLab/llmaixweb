###################  LLMAIx – backend (GPU, non-root) ###################
FROM nvidia/cuda:12.9.1-cudnn-runtime-ubuntu24.04

ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv git curl build-essential \
        tesseract-ocr-* \
        ocrmypdf && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# install uv into a global path accessible for all users
ENV UV_INSTALL_DIR=/opt/uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/opt/uv:${PATH}"

# dependency install
COPY pyproject.toml uv.lock* ./
RUN uv sync

# copy application code last for better caching
COPY backend ./backend

# create non-root user and hand over app dir
RUN groupadd --system --gid 10001 app && \
    useradd --system --uid 10001 --gid app --create-home --home-dir /home/app app && \
    chown -R app:app /app

# activate the virtual env for runtime
ENV PATH="/app/.venv/bin:/opt/uv:${PATH}"

USER 10001:10001

CMD ["uvicorn", "backend.src.main:app", "--host", "0.0.0.0", "--port", "8000"]