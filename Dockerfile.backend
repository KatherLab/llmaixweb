###################  LLMAIx – backend (GPU, non-root) ###################
FROM nvidia/cuda:12.9.1-cudnn-runtime-ubuntu24.04

ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv git curl build-essential \
        tesseract-ocr-* \
        ocrmypdf && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# install uv into a global path accessible for all users
ENV UV_INSTALL_DIR=/opt/uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/opt/uv:${PATH}"

# create non-root user first
RUN groupadd --system --gid 10001 app && \
    useradd --system --uid 10001 --gid app --create-home --home-dir /home/app app

# copy dependency metadata first for better caching
COPY pyproject.toml uv.lock* ./

# prepare ownership before switching user
RUN chown -R app:app /app

USER 10001:10001

# create a standard venv with system python to avoid uv-managed interpreter issues
RUN python3 -m venv /app/.venv

# activate the virtual env for build + runtime
ENV PATH="/app/.venv/bin:/opt/uv:${PATH}"
ENV VIRTUAL_ENV="/app/.venv"

# install dependencies into the existing venv
RUN uv sync --locked

USER root

# copy application code last for better caching
COPY --chown=app:app backend ./backend

USER 10001:10001

CMD ["/app/.venv/bin/python", "-m", "uvicorn", "backend.src.main:app", "--host", "0.0.0.0", "--port", "8000"]