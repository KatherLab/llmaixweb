################### LLMAIx – backend ###################
FROM ghcr.io/astral-sh/uv:latest AS uv

FROM python:3.13-slim-trixie

ARG GIT_COMMIT_HASH=unknown

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:/usr/local/bin:${PATH}" \
    DOCKER_ENV=true

# uv binary
COPY --from=uv /uv /usr/local/bin/uv

WORKDIR /app

# Create non-root user
RUN groupadd --system --gid 10001 app && \
    useradd --system --uid 10001 --gid app --create-home --home-dir /home/app app

# Dependency metadata first for Docker cache
COPY pyproject.toml uv.lock* ./

# Install only production dependencies.
# --no-dev skips [dependency-groups].dev
RUN uv sync --locked --no-dev && uv cache clean

# Copy app code last
COPY --chown=app:app backend ./backend
COPY --chown=app:app alembic ./alembic
COPY --chown=app:app alembic.ini ./alembic.ini
COPY --chown=app:app backend/scripts/run_migrations.sh /app/run_migrations.sh

RUN echo "${GIT_COMMIT_HASH}" > /app/backend/src/_git_commit.txt && \
    chmod +x /app/run_migrations.sh && \
    chown -R app:app /app

USER 10001:10001

CMD ["/app/run_migrations.sh"]
