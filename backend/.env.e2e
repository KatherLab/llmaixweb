# Backend environment for the Playwright e2e smoke test.
#
# Broker-free and deterministic: SQLite + local storage, no Redis/Celery
# (DISABLE_CELERY), and no real LLM (a tiny fake OpenAI server backs it — see
# e2e/support/fake-llm.mjs). Startup LLM/S3 probes are skipped. This file is
# selected via ENV_PATH=backend/.env.e2e by playwright.config.ts's webServer.
SECRET_KEY=e2e-secret-key-not-for-production-000
SQLALCHEMY_DATABASE_URI=sqlite:///./e2e_test.db
LOCAL_DIRECTORY=./e2e_local_storage
DISABLE_CELERY=True
DISABLE_RATE_LIMIT=True
OPENAI_NO_API_CHECK=True
OPENAI_API_BASE=http://127.0.0.1:9099/v1
OPENAI_API_KEY=sk-fake
OPENAI_API_MODEL=fake-model
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DOCLING_LOCAL_FALLBACK=true
