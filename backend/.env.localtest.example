# ──────────────────────────────────────────────────────────────────────────────
# LLMAIx Web - Local Test Environment
# For running backend tests with: ENV_PATH=backend/.env.localtest uv run pytest --verbose --cov=backend --cov-report=html
# ──────────────────────────────────────────────────────────────────────────────

# ═════════════════════════════════════════════════════════════════════════════
# LLM Provider Settings
# ═════════════════════════════════════════════════════════════════════════════
# Set to True to skip API key validation during tests
OPENAI_NO_API_CHECK=True

# OpenAI-compatible API settings (configure for integration tests)
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=
OPENAI_API_MODEL=

# ═════════════════════════════════════════════════════════════════════════════
# Storage: Use local filesystem for tests
# ═════════════════════════════════════════════════════════════════════════════
LOCAL_DIRECTORY=test_local_storage

# ═════════════════════════════════════════════════════════════════════════════
# Celery: Disabled for tests
# ═════════════════════════════════════════════════════════════════════════════
DISABLE_CELERY=True

# ═════════════════════════════════════════════════════════════════════════════
# Database: SQLite for local tests (no external DB required)
# ═════════════════════════════════════════════════════════════════════════════
SQLALCHEMY_DATABASE_URI=sqlite:///./test_llmaixweb.db
