{
  "name": "llmaixwebui",
  "version": "0.6.8",
  "private": true,
  "description": "LLMAIx Web frontend — extract structured JSON from unstructured medical/lab documents with LLMs.",
  "license": "AGPL-3.0-or-later",
  "author": "KatherLab",
  "homepage": "https://github.com/KatherLab/llmaixweb#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/KatherLab/llmaixweb.git"
  },
  "bugs": {
    "url": "https://github.com/KatherLab/llmaixweb/issues"
  },
  "type": "module",
  "//pinia": "Pinned to 3.x: pinia 4.0.1 ships a broken package.json 'exports' map (no 'types' condition), so vue-tsc/Bundler resolution can't find its declarations (TS7016). Revisit once pinia publishes a fixed exports map.",
  "//typescript": "Pinned to 6.x: typescript-eslint (8.x) still requires typescript <6.1.0 and vue-tsc has no TS 7 (native port) support yet. Revisit bumping to 7.x once the lint/type-check toolchain supports it.",
  "scripts": {
    "prebuild": "node frontend/update-version.js",
    "preserve": "node frontend/update-version.js",
    "dev": "node_modules/.bin/vite --config frontend/vite.config.js",
    "build": "node_modules/.bin/vite build --config frontend/vite.config.js",
    "preview": "node_modules/.bin/vite preview --config frontend/vite.config.js",
    "format": "prettier --write \"frontend/**/*.{js,ts,vue,css}\"",
    "format:check": "prettier --check \"frontend/**/*.{js,ts,vue,css}\"",
    "lint": "eslint frontend/",
    "lint:fix": "eslint frontend/ --fix",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "i18n:check": "node scripts/i18n-check.mjs",
    "i18n:usage": "node scripts/i18n-usage-check.mjs",
    "check": "npm run format:check && npm run lint && npm run type-check && npm run i18n:check && npm run i18n:usage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node e2e/support/reset.mjs && playwright test",
    "test:e2e:ui": "node e2e/support/reset.mjs && playwright test --ui"
  },
  "dependencies": {
    "@floating-ui/vue": "2.0.1",
    "@fontsource-variable/inter": "5.2.8",
    "@lucide/vue": "1.25.0",
    "@tailwindcss/vite": "4.3.3",
    "axios": "1.18.1",
    "dompurify": "3.4.12",
    "jszip": "3.10.1",
    "marked": "18.0.6",
    "pinia": "4.0.2",
    "tailwindcss": "4.3.3",
    "vue": "3.5.40",
    "vue-i18n": "11.4.7",
    "vue-router": "5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.1.0",
    "prettier": "3.9.5",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-vue-devtools": "8.1.5",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "lint-staged": {
    "frontend/**/*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.css": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
