{
  "name": "llmaixwebui",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node frontend/update-version.js",
    "preserve": "node frontend/update-version.js",
    "dev": "node_modules/.bin/vite --config frontend/vite.config.js",
    "build": "node_modules/.bin/vite build --config frontend/vite.config.js",
    "preview": "node_modules/.bin/vite preview --config frontend/vite.config.js",
    "format": "prettier --write \"frontend/**/*.{js,vue,css}\"",
    "format:check": "prettier --check \"frontend/**/*.{js,vue,css}\"",
    "lint": "eslint frontend/",
    "lint:fix": "eslint frontend/ --fix",
    "check": "npm run format:check && npm run lint"
  },
  "dependencies": {
    "@floating-ui/vue": "2.0.0",
    "@lucide/vue": "1.21.0",
    "@tailwindcss/vite": "4.3.1",
    "@vueform/multiselect": "2.6.11",
    "autoprefixer": "10.5.1",
    "axios": "1.18.1",
    "chart.js": "4.5.1",
    "crypto-js": "4.2.0",
    "dompurify": "3.4.11",
    "jsonschema": "1.5.0",
    "jszip": "3.10.1",
    "marked": "18.0.5",
    "pinia": "3.0.4",
    "recharts": "3.9.0",
    "tailwindcss": "4.3.1",
    "vue": "3.5.38",
    "vue-chartjs": "5.3.3",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4",
    "simple-git-hooks": "2.13.1",
    "vite": "8.1.0",
    "vite-plugin-vue-devtools": "8.1.3"
  },
  "lint-staged": {
    "frontend/**/*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.css": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
