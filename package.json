{
  "name": "llmaixwebui",
  "version": "0.6.5",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node frontend/update-version.js",
    "preserve": "node frontend/update-version.js",
    "dev": "node_modules/.bin/vite --config frontend/vite.config.js",
    "build": "node_modules/.bin/vite build --config frontend/vite.config.js",
    "preview": "node_modules/.bin/vite preview --config frontend/vite.config.js",
    "format": "prettier --write \"frontend/**/*.{js,ts,vue,css}\"",
    "format:check": "prettier --check \"frontend/**/*.{js,ts,vue,css}\"",
    "lint": "eslint frontend/",
    "lint:fix": "eslint frontend/ --fix",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "check": "npm run format:check && npm run lint && npm run type-check"
  },
  "dependencies": {
    "@floating-ui/vue": "2.0.0",
    "@lucide/vue": "1.23.0",
    "@tailwindcss/vite": "4.3.2",
    "axios": "1.18.1",
    "dompurify": "3.4.12",
    "jszip": "3.10.1",
    "marked": "18.0.5",
    "pinia": "3.0.4",
    "tailwindcss": "4.3.2",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-typescript": "14.9.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vite-plugin-vue-devtools": "8.1.5",
    "vue-tsc": "3.3.7"
  },
  "lint-staged": {
    "frontend/**/*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.css": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
