{
  "name": "llmaixwebui",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node frontend/update-version.js",
    "preserve": "node frontend/update-version.js",
    "dev": "node_modules/.bin/vite --config frontend/vite.config.js",
    "build": "node_modules/.bin/vite build --config frontend/vite.config.js",
    "preview": "node_modules/.bin/vite preview --config frontend/vite.config.js",
    "format": "prettier --write \"frontend/**/*.{js,vue,css}\"",
    "format:check": "prettier --check \"frontend/**/*.{js,vue,css}\"",
    "lint": "eslint frontend/",
    "lint:fix": "eslint frontend/ --fix",
    "check": "npm run format:check && npm run lint"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.0",
    "ag-grid-vue3": "35.3.0",
    "autoprefixer": "10.5.0",
    "axios": "1.16.1",
    "chart.js": "4.5.1",
    "pinia": "3.0.4",
    "recharts": "3.8.1",
    "tailwindcss": "4.3.0",
    "vue": "3.5.35",
    "vue-chartjs": "5.3.3",
    "vue-router": "5.1.0",
    "vue-toastification": "2.0.0-rc.5",
    "jsonschema": "1.5.0",
    "@vueform/multiselect": "2.6.11",
    "marked": "18.0.4",
    "dompurify": "3.4.7",
    "crypto-js": "4.2.0",
    "@floating-ui/vue": "1.1.11",
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@vitejs/plugin-vue": "6.0.7",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.1",
    "globals": "17.6.0",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "vite": "8.0.14",
    "vite-plugin-vue-devtools": "8.1.2"
  },
  "lint-staged": {
    "frontend/**/*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.css": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
