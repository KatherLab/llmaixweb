# ──────────────────────────────────────────────────────────────────────────────
# LLMAIx Web - Environment Configuration
# Copy this file to .env and adjust values for your deployment
# ──────────────────────────────────────────────────────────────────────────────

# ───────── Database ─────────
POSTGRES_SERVER=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=llmaixweb
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://postgres:postgres@postgres/llmaixweb

# ───────── Redis / Celery ─────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
DISABLE_CELERY=false
INITIALIZE_CELERY=false
CELERY_PREPROCESS_POOL=auto

# ───────── Object storage (MinIO/S3) ─────────
# For MinIO (local development):
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=llmaixweb
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# For AWS S3 or other S3-compatible storage, set:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT_URL=https://s3.region.amazonaws.com (or omit for AWS default)
# S3_BUCKET_NAME=your-bucket-name

# ───────── Local Storage (alternative to S3) ─────────
# Set LOCAL_DIRECTORY to store files locally instead of S3
# LOCAL_DIRECTORY=/path/to/storage

# ───────── OpenAI / LLM Provider ─────────
# Works with official OpenAI or compatible APIs (vLLM, Ollama, llama.cpp, etc.)
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_API_MODEL=
OPENAI_NO_API_CHECK=true

# ───────── CORS & Frontend ─────────
BACKEND_CORS_ORIGINS=http://localhost:5173

# Frontend backend URL (used in docker-compose as runtime env var)
# For production: VITE_API_BACKEND_URL=https://api.yourdomain.com/api/v1
VITE_API_BACKEND_URL=http://localhost:8000/api/v1

# ───────── Security / Access Control ─────────
REQUIRE_INVITATION=false
ALLOW_FIRST_ADMIN_SETUP=true

# ───────── Application ─────────
PROJECT_NAME=LLMAIx (v2) backend