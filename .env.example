# ──────────────────────────────────────────────────────────────────────────────
# LLMAIx Web - Environment Configuration
# Copy this file to .env and adjust values for your deployment
# ──────────────────────────────────────────────────────────────────────────────
#
# QUICK START: For a basic test setup, only configure:
#   - OPENAI_API_KEY, OPENAI_API_BASE, OPENAI_API_MODEL (LLM provider)
#   - SECRET_KEY (generate random string for production)
#   Note: OPENAI_API_KEY/BASE/MODEL are empty by default. The app will start
#   but extraction trials won't work until you fill these in or configure
#   a provider in the admin panel.
# OCR: Docling-serve (Tesseract) handles PDF/image OCR and embedded PDF text
#   extraction — enabled by default in the docker-compose stack.
#   Mistral OCR and Vision LLM API keys are set per-task in the UI.
# All other defaults work with docker-compose out of the box.
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEV (no Docker): uncomment to run the backend directly against SQLite +
# local-file storage with tasks executed synchronously (no Postgres/Redis/S3).
# These override the docker-shaped hostnames below (postgres/redis/rustfs only
# resolve inside compose). Run from the repo ROOT:
#     uv sync && uv run uvicorn backend.src.main:app --reload
#   SQLALCHEMY_DATABASE_URI=sqlite:///./llmaixweb.db
#   LOCAL_DIRECTORY=./local_storage
#   DISABLE_CELERY=true          # run preprocessing/trials inline (no Redis needed)
#   DOCLING_LOCAL_FALLBACK=true  # embedded Docling OCR without docling-serve
# ──────────────────────────────────────────────────────────────────────────────

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED: LLM Provider Configuration
# ═════════════════════════════════════════════════════════════════════════════
# Works with official OpenAI or compatible APIs (vLLM, Ollama, llama.cpp, etc.)
#
# For self-hosted vLLM endpoint via compose.vllm.yml, uncomment:
#   docker compose -f compose.yml -f compose.vllm.yml up -d
# Then use:
#   OPENAI_API_BASE=http://vllm:8000/v1
#   OPENAI_API_KEY=sk-noop
#   OPENAI_API_MODEL=google/gemma-4-E4B-it
#   OPENAI_NO_API_CHECK=false
#
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_API_MODEL=
# Skip the startup connectivity/model check so the app boots without an LLM key
# configured (trials still need one — fill the three vars above, or add a
# provider in the admin panel). Set to false to validate the key/model on boot.
# Code default is false; shipped as true here so a fresh install starts cleanly.
OPENAI_NO_API_CHECK=true

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED: Security
# ═════════════════════════════════════════════════════════════════════════════
# Generate a random secret for production (MANDATORY — app will not start without it)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
# Access-token lifetime in minutes (default: 60). Kept short for PHI — refresh
# tokens (rotated, revocable) transparently re-issue access tokens and the
# frontend silently refreshes, so a short window limits a leaked token's blast
# radius. Raise only if a longer session is genuinely required.
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Egress allowlist (restrict where patient data may be sent) ───────────────
# Comma-separated host allowlists for user-supplied LLM / OCR endpoints. Empty
# (default) = any host allowed, subject to the SSRF policy. In a clinic, set
# these to your approved (ideally on-prem) hosts so trials/OCR can't send PHI
# anywhere else. Matches exact host or subdomain (example.com ⇒ api.example.com).
# ALLOWED_LLM_ENDPOINTS=vllm,api.example.com
# ALLOWED_OCR_ENDPOINTS=ocr-api,vllm

# Access control
# REQUIRE_INVITATION: require an invitation token to register. Code default is
# TRUE; the docker-compose stack sets it to FALSE (open registration). Uncomment
# to override the compose default.
# REQUIRE_INVITATION=true
# ALLOW_FIRST_ADMIN_SETUP=true
# Invitation token lifetime in hours (default: 168 = 7 days; 0 = never expire)
# INVITATION_EXPIRE_HOURS=168

# ADMIN_ALL_PROJECT_ACCESS: by default (false) admins can only see and manage
# their OWN projects, like any other user. Set true to grant admins read/write
# access to ALL users' projects (and their live task updates). Env-only by
# design — it is intentionally NOT exposed in the admin settings UI so it can't
# be toggled at runtime.
# ADMIN_ALL_PROJECT_ACCESS=false

# ── Password policy ──────────────────────────────────────────────────────────
# Enforced centrally for every password-setting flow (register, first-admin,
# change password, admin set-password, reset). Min length is also enforced by
# the request schemas; the validator adds the character-class rules below.
# PASSWORD_POLICY_MIN_LENGTH=8
# PASSWORD_POLICY_MAX_LENGTH=128
# PASSWORD_POLICY_REQUIRE_UPPERCASE=true
# PASSWORD_POLICY_REQUIRE_LOWERCASE=true
# PASSWORD_POLICY_REQUIRE_DIGIT=true
# PASSWORD_POLICY_REQUIRE_SYMBOL=false

# ── Account lockout (brute-force protection) ─────────────────────────────────
# After LOGIN_MAX_ATTEMPTS failed logins, the account is locked for
# LOGIN_LOCKOUT_MINUTES. The IP rate limit (10/min on /login) is the first
# line of defense; this is the per-account backstop.
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# ── Refresh tokens ───────────────────────────────────────────────────────────
# Refresh tokens are hash-stored, rotated on each use, and revocable.
# Issued alongside the access token on login; the frontend silently refreshes
# on 401. Does not shorten the access-token lifetime above.
# REFRESH_TOKEN_EXPIRE_DAYS=30

# ═════════════════════════════════════════════════════════════════════════════
# SSO / OPENID CONNECT (optional)
# ═════════════════════════════════════════════════════════════════════════════
# Enable OpenID Connect single sign-on. When enabled, admins configure
# individual providers (Google, Keycloak, Azure AD, …) in the Admin → SSO
# panel; the login page then shows "Continue with {Provider}" buttons.
# SSO_ENABLED=false
#
# Role assigned to users auto-created on first SSO login (JIT provisioning).
# SSO_JIT_DEFAULT_ROLE=user
#
# When true, SSO login bypasses REQUIRE_INVITATION (the IdP is the trust
# source, not an invitation token). Set false to keep SSO invitation-gated.
# SSO_BYPASS_INVITATION=true
#
# Optional: explicit Fernet key for encrypting provider client secrets at
# rest. If empty, a key is derived from SECRET_KEY (sufficient for most
# deployments; set explicitly only to rotate independently of SECRET_KEY).
# SSO_CLIENT_SECRET_ENCRYPTION_KEY=
#
# Provider setup (done in Admin → SSO, not here):
#   - Display name, Issuer URL (e.g. https://accounts.google.com)
#   - Client ID + Client secret (encrypted at rest)
#   - Scopes (default: "openid email profile")
# The callback URL registered with the IdP is:
#   {APP_URL}/api/v1/auth/sso/{provider-slug}/callback

# ═════════════════════════════════════════════════════════════════════════════
# STORAGE: Choose ONE option below
# ═════════════════════════════════════════════════════════════════════════════
# Option A: RustFS/MinIO (default for docker-compose)
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
S3_ENDPOINT_URL=http://rustfs:9000
S3_BUCKET_NAME=llmaixweb
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

# Option B: AWS S3 (uncomment and configure for AWS)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT_URL=https://s3.region.amazonaws.com
# S3_BUCKET_NAME=your-bucket-name

# Option C: Local filesystem (alternative to S3)
# LOCAL_DIRECTORY=/path/to/storage

# ═════════════════════════════════════════════════════════════════════════════
# DATABASE (default works with docker-compose — change only for external DB)
# ═════════════════════════════════════════════════════════════════════════════
# Note: host is "postgres" for Docker, Python default is "localhost" for dev.
# Change the password here in ONE place — the URI below is derived from these
# POSTGRES_* values automatically, so leave SQLALCHEMY_DATABASE_URI commented
# out unless you point at an external database.
POSTGRES_SERVER=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=llmaixweb
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg://user:password@host/dbname

# ═════════════════════════════════════════════════════════════════════════════
# CELERY (defaults work with docker-compose)
# ═════════════════════════════════════════════════════════════════════════════
CELERY_BROKER_URL=redis://redis:6379/0
# DISABLE_CELERY=false
# INITIALIZE_CELERY: spawn in-process Celery workers on startup. Code default is
# TRUE (handy for bare-metal / single-process runs). The docker-compose stack
# sets it FALSE and runs dedicated worker containers instead.
# INITIALIZE_CELERY=false
# Use 'solo' on macOS to avoid multiprocessing issues
# CELERY_PREPROCESS_POOL=auto

# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND & CORS
# ═════════════════════════════════════════════════════════════════════════════
# The public URL of the app, used to construct invitation/password-reset links.
# Default: http://localhost:5173
# APP_URL=http://localhost:5173
# CORS origins — comma-separated. Only needed for multi-domain setups.
# In the default single-domain deployment (nginx proxies /api/ to backend), CORS is not required.
# BACKEND_CORS_ORIGINS=http://localhost:5173

# ═════════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═════════════════════════════════════════════════════════════════════════════
# PROJECT_NAME='LLMAIx (v2) backend'

# ── Site-wide banner ─────────────────────────────────────────────────────────
# Optional notice bar shown at the very top of every page (login/landing too),
# e.g. "Research Use Only!". Can also be toggled at runtime in the admin
# settings panel (Admin → Settings → General). Uncomment to set a default here.
# BANNER_ENABLED=true
# BANNER_TEXT='Research Use Only!'
# Banner color scheme: amber (default), red, blue, green, or gray.
# BANNER_COLOR=amber

# ═════════════════════════════════════════════════════════════════════════════
# LOGGING (optional — defaults to INFO / text)
# ═════════════════════════════════════════════════════════════════════════════
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=DEBUG
#
# Output format: "text" (human-readable, default) or "json" (structured, one
# object per line — set this in production and ship stdout to your SIEM/Loki).
# Every log line, the append-only audit trail, and the central error log share
# a per-request correlation id, so you can pivot across all three by that id.
# LOG_FORMAT=json
#
# Accountability: an append-only audit log (auth, PHI access, mutations,
# external egress, admin changes) and a central error log are always on and
# viewable at Admin → Audit Log. Unhandled errors return a short error id the
# user can quote to an admin. See docs/AUDIT_LOGGING.md.

# ═════════════════════════════════════════════════════════════════════════════
# OCR & TEXT EXTRACTION (optional — set server-level defaults here)
# ═════════════════════════════════════════════════════════════════════════════
#
# Privacy control: allow OCR to fall back to a remote/API engine (Mistral,
# Vision LLM) when the local engine is unavailable. Default is FALSE — keep it
# false to guarantee documents never leave the host during preprocessing.
# REMOTE_OCR_FALLBACK_ENABLED=false
#
# ─────────────────────────────────────────────────────────────────────────────
# Local OCR (Docling-serve)
# ─────────────────────────────────────────────────────────────────────────────
# Docling-serve handles embedded PDF text extraction and local Tesseract OCR.
# The docker-compose stack enables it by default; the code default is DISABLED,
# so for a bare-metal run set DOCLING_SERVE_ENABLED=true (or DOCLING_LOCAL_FALLBACK=true
# for embedded Docling) to get an OCR engine.
#
# DOCLING_SERVE_ENABLED=true
# DOCLING_SERVE_URL=http://docling-serve:5001
# DOCLING_SERVE_DISPLAY_NAME='Quick (Local OCR)'
# DOCLING_SERVE_DISPLAY_SUBTITLE='Docling / Tesseract'
#   ^ Customize display names in the UI
#
# ─────────────────────────────────────────────────────────────────────────────
# Mistral OCR API
# ─────────────────────────────────────────────────────────────────────────────
# For self-hosted Mistral OCR via DeepSeek-OCR-2 + KatDocExtract, use:
#   docker compose -f compose.yml -f compose.deepseek.yml up -d
#
# MISTRAL_API_BASE=https://api.mistral.ai
# For local DeepSeek-OCR-2 stack, uncomment:
#   MISTRAL_API_BASE=http://ocr-api:8001
#   MISTRAL_API_KEY=sk-noop
# MISTRAL_API_KEY=
# MISTRAL_OCR_ENABLED=false
# MISTRAL_OCR_MODEL=mistral-ocr-latest
#   ^ Model name for display/metadata when using custom Mistral OCR endpoints (e.g., DeepSeek-OCR-2)
# MISTRAL_OCR_DISPLAY_NAME='Mistral OCR API'
# MISTRAL_OCR_DISPLAY_SUBTITLE='Best for complex layouts'
#   ^ Customize display names in the UI

# Vision LLM OCR — separate endpoint for OCR via vision models.
# If unset, the frontend falls back to the main LLM client. Set to false to disable entirely.
#
# For self-hosted vision LLM via vLLM (e.g., Gemma 4 4B), use:
#   docker compose -f compose.yml -f compose.vllm.yml up -d
# Then uncomment and adjust:
#   VISION_OCR_API_BASE=http://vllm:8000/v1
#   VISION_OCR_MODEL=google/gemma-4-E4B-it
#
# VISION_OCR_ENABLED=false
#   ^ Can also be toggled via Admin Settings UI
# VISION_OCR_API_KEY=
# VISION_OCR_API_BASE=
# VISION_OCR_MODEL=gpt-4o
# VISION_OCR_DISPLAY_NAME='Vision LLM API'
# VISION_OCR_DISPLAY_SUBTITLE='Best for complex documents'
#   ^ Customize display names in the UI
# Default prompt for the Vision LLM OCR — can be overridden per-task in the preprocessing UI.
# Controls how the vision model is instructed to extract text from page images.
# VISION_OCR_PROMPT='Extract all text from this image and return it as clean markdown. Preserve the original structure, headings, lists, and formatting as much as possible.'

# ═════════════════════════════════════════════════════════════════════════════
# EMAIL / SMTP (optional — for invitation & password reset emails)
# ═════════════════════════════════════════════════════════════════════════════
# Email delivery is disabled by default. Set EMAIL_ENABLED=true and configure
# SMTP settings to enable sending invitation and password reset emails.
# When disabled, invitations fall back to manual link copy, and password reset
# shows a warning that email delivery is not configured.
#
# Typical SMTP configuration for Gmail App Password:
#   EMAIL_ENABLED=true
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=your@gmail.com
#   SMTP_PASSWORD=your-app-password
#   SMTP_FROM_ADDRESS=your@gmail.com
#   SMTP_FROM_NAME=LLMAIx Web
#   SMTP_USE_TLS=true
#
# EMAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=
# SMTP_FROM_NAME=LLMAIx Web
# SMTP_USE_TLS=true

# OCR Engine Display Names (customizable in Admin Settings UI)
# Admins can rebrand OCR engines to show custom names in the UI.
# These defaults can be overridden via the Admin Settings page.
# MISTRAL_OCR_DISPLAY_NAME='Mistral OCR API'
# MISTRAL_OCR_DISPLAY_SUBTITLE='Best for complex layouts'
# When using compose.deepseek.yml (KatDocExtract), uncomment for friendly naming:
#   MISTRAL_OCR_DISPLAY_NAME='DeepSeek OCR (local)'
#   MISTRAL_OCR_DISPLAY_SUBTITLE='Self-hosted via KatDocExtract'
# VISION_OCR_DISPLAY_NAME='Vision LLM API'
# VISION_OCR_DISPLAY_SUBTITLE='Best for complex documents'
# When using compose.vllm.yml (self-hosted vLLM), uncomment for friendly naming:
#   VISION_OCR_DISPLAY_NAME='vLLM Vision OCR (local)'
#   VISION_OCR_DISPLAY_SUBTITLE='Self-hosted via vLLM + Gemma 4'
