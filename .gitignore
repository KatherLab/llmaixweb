# Environment files (never commit secrets)
.env
.env.*
.env.local
backend/.env
frontend/.env
# Exception: the e2e backend env holds only fake/test values (no real secrets)
# and is needed to run the Playwright smoke in CI.
!backend/.env.e2e

# Database
database.db

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
*/dist

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
~$*.xlsx

# Local development
miniodata/
test_local_storage/

# Agents
.claude
# MkDocs local build output
/site/

# Playwright e2e (ephemeral backend state + reports)
/e2e_test.db
/e2e_test.db-wal
/e2e_test.db-shm
/e2e_local_storage/
/test-results/
/playwright-report/
/blob-report/
